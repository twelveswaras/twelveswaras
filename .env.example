# Template for local secrets. Copy to .env (which is gitignored) and fill in real values.
# NEVER commit real tokens. See cloudflare/DEPLOY.md for what the token needs to be scoped to.

# Scoped Cloudflare API token (Account: Workers Scripts/D1/R2/Pages = Edit, Account Settings = Read;
# later add Zone: Read + DNS/Workers Routes = Edit once twelveswaras.com is on Cloudflare).
CLOUDFLARE_API_TOKEN=your-scoped-cloudflare-token

# Optional Hugging Face write token (only if not logged in via huggingface-cli).
# HF_TOKEN=your-hf-write-token
